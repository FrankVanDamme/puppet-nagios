<% if scope.lookupvar("osfamily") == "Debian" -%>
## APT Updates
define service {
    host_name           <%= @host_name %>
    service_description APT_Updates
    check_command       check_nrpe_timeout!check_apt
    use                 <%= @use %>
    notifications_enabled 0 
    normal_check_interval 60
    retry_check_interval 20
}
<% end -%>
<% if scope.lookupvar("osfamily") == "RedHat" -%>
## Yum Updates
define service {
    host_name           <%= @host_name %>
    service_description YUM_Updates
    check_command       check_nrpe_noarg!check_yum
    use                 <%= @use %>
    notifications_enabled 0 
    normal_check_interval 60
    retry_check_interval 20
}
<% end -%>
